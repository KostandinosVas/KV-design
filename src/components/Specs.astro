---

---

<section class="page-section section-specs" id="specs">
  <div class="specs-inner">
    <div class="specs-image">
      <img
        src="/images/drones/veit-hammer-T9_700nqo8A-unsplash.jpg"
        alt="Kargia-69 drone close-up"
      />
    </div>
    <div class="specs-content">
      <h2>Technical Specifications</h2>
      <p class="specs-intro">
        Built for professionals who demand precision and hobbyists who live for
        adventure. Every gram optimized, every parameter tunable.
      </p>
      <dl class="spec-list">
        <div class="spec-row">
          <dt>Weight</dt>
          <dd>895 g (with battery)</dd>
        </div>
        <div class="spec-row">
          <dt>Max Speed</dt>
          <dd>87 km/h (Sport mode)</dd>
        </div>
        <div class="spec-row">
          <dt>Flight Time</dt>
          <dd>38 min (standard conditions)</dd>
        </div>
        <div class="spec-row">
          <dt>Range</dt>
          <dd>15 km (O3+ link)</dd>
        </div>
        <div class="spec-row">
          <dt>Camera</dt>
          <dd>4K / 120fps &mdash; 1/1.3" CMOS</dd>
        </div>
        <div class="spec-row">
          <dt>Gimbal</dt>
          <dd>3-axis mechanical, ±0.01° stability</dd>
        </div>
        <div class="spec-row">
          <dt>Wind Resistance</dt>
          <dd>Level 5 (up to 60 km/h)</dd>
        </div>
        <div class="spec-row">
          <dt>GPS</dt>
          <dd>GPS + GLONASS + Galileo tri-band</dd>
        </div>
        <div class="spec-row">
          <dt>Obstacle Avoidance</dt>
          <dd>6-directional sensing (omnidirectional)</dd>
        </div>
        <div class="spec-row">
          <dt>Charging Time</dt>
          <dd>52 min (100W fast charger)</dd>
        </div>
        <div class="spec-row">
          <dt>Folded Dimensions</dt>
          <dd>207 × 96 × 93 mm</dd>
        </div>
        <div class="spec-row">
          <dt>IP Rating</dt>
          <dd>IP54 splash & dust resistant</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
